# Dependencies: ignore the composer tree EXCEPT the vendored update-checker,
# which must ship with the plugin so wp-admin auto-updates work.
/vendor/*
!/vendor/plugin-update-checker/

# Composer
composer.lock

# OS / editor cruft
.DS_Store
Thumbs.db
*.log

# Node (if a build step is added later)
/node_modules/

# Generated image mirror (tools/mirror-images.js). NOT bundled: the captured set is
# only a subset of all option combinations, so the preview hotlinks the Endurance host
# by default. For full self-hosting, mirror to a CDN and set "Preview image base URL".
/assets/img/endurance/

# Keep the data folder but ignore the (potentially large, ToS-sensitive) full catalogue
# by default — un-ignore it if you want it committed/shipped in the release.
# /data/endurance-catalogue-full.json

# Brainstorming visual companion
.superpowers/
samples/
.claude/
data/endurance-patch.json

# Client PDFs (PII) and local tool settings — never commit
